{
  "name": "phantom-embedded-react-native-starter",
  "version": "1.0.0",
  "description": "A minimal Expo starter template for integrating Phantom's embedded user wallets on Solana for mobile apps",
  "displayName": "Phantom Embedded React Native Starter",
  "usecase": "wallet",
  "author": "Phantom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/phantom/phantom-embedded-react-native-starter"
  },
  "main": "./polyfills.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild"
  },
  "create-solana-dapp": {
    "instructions": [
      "🎉 Your Phantom Embedded React Native starter is ready!",
      "",
      "📋 Next steps:",
      "+1. Copy .env.example to .env and add your Phantom App ID",
      "+2. Get your App ID at https://phantom.app/developer",
      "+3. Read the docs at https://docs.phantom.com/sdks/react-native-sdk",
      "",
      "🚀 Start developing:",
      "+{pm} start",
      "",
      "⚠️ Important: You need a development build to test:",
      "+{pm} run android  # or {pm} run ios",
      "",
      "📚 Learn more:",
      "- React Native SDK Docs: https://docs.phantom.com/sdks/react-native-sdk",
      "- Expo Development Builds: https://docs.expo.dev/develop/development-builds/introduction/",
      "- Get Support: https://discord.gg/phantom"
    ],
    "rename": {
      "phantom-embedded-react-native-starter": {
        "to": "{{name}}",
        "paths": [
          "app",
          "components",
          "lib",
          "package.json",
          "README.md",
          "app.json"
        ]
      }
    }
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@expo/vector-icons": "^15.0.3",
    "@phantom/api-key-stamper": "^1.0.0",
    "@phantom/base64url": "^1.0.0",
    "@phantom/crypto": "^1.0.0",
    "@phantom/react-native-sdk": "1.0.0-beta.26",
    "@phantom/sdk-types": "^1.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native/assets-registry": "^0.83.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "abort-controller": "^3.0.0",
    "axios": "^1.13.2",
    "buffer": "^6.0.3",
    "event-target-shim": "^6.0.2",
    "expo": "~54.0.0",
    "expo-auth-session": "~7.0.9",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.7",
    "expo-crypto": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-random": "^14.0.1",
    "expo-router": "~6.0.15",
    "expo-secure-store": "~15.0.7",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-get-random-values": "~1.11.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-shimmer-placeholder": "^2.0.9",
    "react-native-svg": "15.12.1",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/node": "^24.10.0",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "packageManager": "pnpm@10.20.0"
}
