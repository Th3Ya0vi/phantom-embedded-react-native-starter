{
  "expo": {
    "name": "GeSIM",
    "slug": "gesim",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/default.png",
    "userInterfaceStyle": "dark",
    "scheme": "phantomwallet",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#2F66F6"
    },
    "extra": {
      "eas": {
        "projectId": "c391ca2f-7589-4a6b-88aa-83c58eb0c937"
      }
  },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gesim.phantomwallet",
      "appleTeamId": "837KBXFC63",
      "icon": "./assets/default.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/default.png",
        "monochromeImage": "./assets/android-notification-icon.png",
        "backgroundColor": "#2F66F6"
      },
      "package": "com.gesim.phantomwallet",
      "icon": "./assets/default.png",
      "launchMode": "singleTask",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "phantomwallet"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c391ca2f-7589-4a6b-88aa-83c58eb0c937"
      }
    }
  }
}
