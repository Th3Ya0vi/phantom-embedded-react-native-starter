{
  "expo": {
    "name": "GeSIM",
    "slug": "gesim",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/default.png",
    "userInterfaceStyle": "dark",
    "scheme": "phantomwallet",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#2F66F6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gesim.phantomwallet",
      "appleTeamId": "837KBXFC63",
      "icon": "./assets/default.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/default.png",
        "monochromeImage": "./assets/android-notification-icon.png",
        "backgroundColor": "#2F66F6"
      },
      "package": "com.gesim.phantomwallet",
      "icon": "./assets/default.png"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ]
  }
}
